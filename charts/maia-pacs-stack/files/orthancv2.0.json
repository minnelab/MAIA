{
    /*"Name": "Orthanc demo",*/
    "PostgreSQL": {
        "Host": "orthanc-index",
        "IndexConnectionsCount": 40
    },

        "Education" : {
          "Enabled" : false,
          "PublicRoots" : [
            "http://localhost:8042"
          ],
          "Administrators" : {
            "Authentication" : "Login",
            "Credentials" : {
              "admin" : "admin"
            }
          },
          "StandardUsers" : {
            "Authentication" : "Login",
            "Credentials" : {
              "learner" : "learner"
            }
          },
          "WholeSlideImagingDicomizer" : "/usr/local/bin/OrthancWSIDicomizer",
          "OpenSlideLibrary" : "libopenslide.so.0"
        },
        "OrthancExplorer2" : {
          "IsDefaultOrthancUI": true,
           "CustomLogoPath": "/MAIA_Logo.png",
           "CustomCssPath": "/custom.css",
           "Theme": "dark",
            "UiOptions": {
              "NewWorklistDefaultTags": {
                "PatientID": {
                    "Required": true
                },
                "PatientBirthDate": {
                },
                "PatientName": {
                    "Required": true,
                    "PatientNameType": "Computed",
                    "ComputedFrom": ["lastName", "firstName"]
                },
                "PatientSex": {
                    "Choices": ["F", "M", "U", "O"]
                },
                "StudyInstanceUID": {
                    "DefaultValue": "$$GENERATE_DICOM_UUID$$",
                    "Editable": false
                },
                "InstitutionName": {
                    "DefaultValue": "My institution"
                },
                "ScheduledProcedureStepSequence": {
                    "DefaultValue": [
                        {
                            "ScheduledProcedureStepStartDate": {
                                "DefaultValue": "$$TODAY$$",
                                "Required": true
                            },
                            "Modality": {
                                "Choices": ["DX", "US"],
                                "DefaultValue": "DX",
                                "Required": true
                            },
                            "ScheduledProcedureStepDescription": {
                            }
                        }
                    ]
                }
              },
              "StudyListSearchMode": "search-button",
              "EnableLinkToLegacyUi": false,
              "EnableApiViewMenu": true,
              "ViewersIcons" : {
                "osimis-web-viewer": "bi bi-eye",
                "stone-webviewer": "bi bi-eye-fill",
                "ohif": "bi bi-grid",
                "ohif-vr": "bi bi-grid-1x2",
                "ohif-tmtv": "bi bi-grid-3x3-gap",
                "ohif-seg": "fa-solid fa-shapes fa-button",
                "ohif-micro": "fa-solid fa-microscope fa-button",
                "meddream": "bi bi-columns-gap",
                "volview": "bi bi-box",
                "wsi": "fa-solid fa-microscope fa-button"
              },
              "StudyListColumns" : [
                "PatientBirthDate",
                "PatientName",
                "PatientID",
                "StudyDescription",
                "StudyDate",
                "InstitutionName",
                "modalities",
                "AccessionNumber",
                "seriesAndInstancesCount"
              ],
              "CustomButtons": {
                "bulk-studies": [
                  {
                    "Id": "bulk-get-archive",
                    "Tooltip": "BULK GET ARCHIVE",
                    "HttpMethod": "GET",
                    "Target": "_self",
                    "Icon": "bi bi-archive",
                    "Url": "http://localhost:8042/ohif/viewer?StudyInstanceUIDs={StudyInstanceUIDs}",
                    //"Url": "../../tools/create-archive?resources={CommaSeparatedUUIDs}",
                    "StartMessage": "This is a toast message from BULK GET ARCHIVE"
                  }
                ]
              },
              "DateFormat": "dd/MM/yyyy"
            }
          },

          "Worklists": {
            "Enable": true,
            "SaveInOrthancDatabase": true
          },

    "AdvancedStorage": {
        "Enable": true,
        //"NamingScheme": "dicom/{split(StudyDate)}/{StudyInstanceUID} - {PatientID}/{SeriesInstanceUID}/{pad6(InstanceNumber)} - {UUID}{.ext}",
        "NamingScheme": "dicom/{PatientID} - {PatientName}/{StudyDate} - {StudyInstanceUID} - {StudyDescription}/{SeriesInstanceUID}/{UUID}{.ext}",
        "MaxPathLength": 500,
        "OtherAttachmentsPrefix": "attachments/",
        "MultipleStorages": {
            "Storages": {
                "1": "/orthanc-storage-1"
            },
            // the storage on which new data is stored.
            // There's currently no automatic changes of disks
            "CurrentWriteStorage": "1"
        },
        "DelayedDeletion": {
            "Enable": true
            //"ThrottleDelayMs": 50
        },
        "Indexer": {
            "Enable": true,
            "Folders": [
                "/folder-to-index"
            ]
        }
    }
}